function(avr_get_memory_sizes MCU FLASH_OUT RAM_OUT PROM_OUT)
    if("${MCU}" STREQUAL "atmega16")
        set(flash 16384)
        set(ram   1024)
        set(prom  512)
    elseif("${MCU}" STREQUAL "atmega16a")
        set(flash 16384)
        set(ram   1024)
        set(prom  512)
    elseif("${MCU}" STREQUAL "atmega3208")
        set(flash 32768)
        set(ram   4096)
        set(prom  256)
    elseif("${MCU}" STREQUAL "atmega4808")
        set(flash 49152)
        set(ram   6144)
        set(prom  256)
    elseif("${MCU}" STREQUAL "atmega4809")
        set(flash 49152)
        set(ram   6144)
        set(prom  256)
    elseif("${MCU}" STREQUAL "attiny402")
        set(flash 4096)
        set(ram   256)
        set(prom  128)
    elseif("${MCU}" STREQUAL "attiny406")
        set(flash 4096)
        set(ram   256)
        set(prom  128)
    elseif("${MCU}" STREQUAL "attiny1604")
        set(flash 16384)
        set(ram   1024)
        set(prom  256)
    elseif("${MCU}" STREQUAL "attiny1606")
        set(flash 16384)
        set(ram   1024)
        set(prom  256)
    else()
        message(FATAL_ERROR "No memory sizes known for MCU ${MCU}")
    endif()

    set(${FLASH_OUT} ${flash} PARENT_SCOPE)
    set(${RAM_OUT}   ${ram}   PARENT_SCOPE)
    set(${PROM_OUT}  ${prom}  PARENT_SCOPE)
endfunction()